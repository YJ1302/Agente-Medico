# =====================================================================
# UPeU Internado 360 — Environment configuration example
# Copy this file to `.env` and adjust values for your machine.
#   Windows:  copy .env.example .env
# Never commit the real .env file. No production secrets belong here.
# =====================================================================

# Application
APP_NAME=UPeU Internado 360
APP_ENV=development
DEBUG=true

# Demo mode: when true, the login page shows the seeded demo credentials.
# Set to false for any non-demo deployment.
DEMO_MODE=true

# Security
# Generate a real secret for anything beyond local demos, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production-please-use-a-long-random-value
SESSION_COOKIE_NAME=internado360_session
SESSION_MAX_AGE=28800

# Database (SQLite for the prototype; swap the URL for PostgreSQL later)
DATABASE_URL=sqlite:///./app/data/internado360.db

# Server
HOST=127.0.0.1
PORT=8000

# Logging
LOG_LEVEL=INFO
